# Copy to terraform.tfvars (gitignored) or pass via -var-file=~/workspace/tfvars/hyperlight.tfvars
subscription_id = "00000000-0000-0000-0000-000000000000"
location        = "australiaeast"
vm_size         = "Standard_D4s_v5"
admin_username  = "azureuser"

# Contents of your SSH PUBLIC key (e.g. ~/.ssh/id_ed25519.pub)
ssh_public_key = "ssh-ed25519 AAAA... you@host"

# Lock SSH to YOUR public IP /32 (find it: curl https://api.ipify.org)
ssh_source_cidr = "203.0.113.10/32"
